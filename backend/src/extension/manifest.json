{
  "manifest_version": 3,
  "name": "DevBrain",
  "version": "1.0",
  "permissions": ["contextMenus", "activeTab", "notifications"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png"
    }
  }
}
